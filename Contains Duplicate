class Solution {
    public boolean containsDuplicate(int[] nums) {
        HashMap<Integer,Integer> hm=new HashMap<>();
        for(int i=0;i<nums.length;i++){
            int s=nums[i];
            hm.put(s,hm.getOrDefault(s,0)+1);
        }
        for(int i=0;i<nums.length;i++){
            int s=nums[i];
        if(hm.get(s)>1){
            return true;
        }
        }
        return false;
    }
}
